{
  "version": 2,
  "functions": {
    "api/claude.js":   { "memory": 256, "maxDuration": 30 },
    "api/checkout.js": { "memory": 256, "maxDuration": 10 },
    "api/verify.js":   { "memory": 256, "maxDuration": 10 },
    "api/webhook.js":  { "memory": 256, "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/claude",   "dest": "/api/claude.js"   },
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/verify",   "dest": "/api/verify.js"   },
    { "src": "/api/webhook",  "dest": "/api/webhook.js"  },
    { "src": "/(.*)",         "dest": "/$1"              }
  ]
}
